// Prisma 7 — new TypeScript client generator + driver adapters.
// Docs: https://www.prisma.io/docs/guides/frameworks/nestjs
generator client {
  provider     = "prisma-client"
  output       = "./generated"
  runtime      = "nodejs"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  member
}

enum InstanceRole {
  owner
  operator
  viewer
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  username  String   @unique
  password  String
  role      Role     @default(member)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  instances   Instance[]
  webhooks    Webhook[]
  memberships InstanceMember[]

  @@map("users")
}

enum InstanceStatus {
  new
  connecting
  awaiting_qr
  password_required
  authorized
  disconnected
  error
}

enum PeerType {
  user
  group
  channel
}

enum MediaType {
  none
  photo
  video
  document
  audio
  sticker
  other
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model Instance {
  id         String         @id @default(uuid())
  ownerId    String
  owner      User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  label      String
  engine     String         @default("gramjs")
  status     InstanceStatus @default(new)
  apiId      Int?
  apiHashEnc String?
  tgUserId   BigInt?
  firstName  String?
  username   String?
  phone      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  chats        Chat[]
  contacts     Contact[]
  messages     Message[]
  webhookLinks WebhookInstance[]
  members      InstanceMember[]

  @@index([ownerId])
  @@map("telegram_instances")
}

model InstanceMember {
  instanceId String
  instance   Instance     @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       InstanceRole @default(viewer)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@id([instanceId, userId])
  @@index([userId])
  @@map("instance_members")
}

model Contact {
  id         String   @id @default(uuid())
  instanceId String
  instance   Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  tgUserId   BigInt
  accessHash BigInt?
  firstName  String?
  lastName   String?
  username   String?
  phone      String?
  hasPhoto   Boolean  @default(false)
  isContact  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  messages Message[] @relation("MessageSender")

  @@unique([instanceId, tgUserId])
  @@map("telegram_contacts")
}

model Chat {
  id            String    @id @default(uuid())
  instanceId    String
  instance      Instance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  tgPeerId      BigInt
  type          PeerType
  accessHash    BigInt?
  title         String?
  username      String?
  hasPhoto      Boolean   @default(false)
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  messages Message[]

  @@unique([instanceId, tgPeerId])
  @@index([instanceId, lastMessageAt])
  @@map("telegram_chats")
}

model Message {
  id          String    @id @default(uuid())
  instanceId  String
  instance    Instance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  chatId      String
  chat        Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  tgMessageId BigInt
  senderId    String?
  sender      Contact?  @relation("MessageSender", fields: [senderId], references: [id], onDelete: SetNull)
  outgoing    Boolean   @default(false)
  text        String?
  mediaType   MediaType @default(none)
  mediaRef    Json?
  replyToTgId BigInt?
  date        DateTime
  editedAt    DateTime?
  createdAt   DateTime  @default(now())

  @@unique([instanceId, chatId, tgMessageId])
  @@index([chatId, date])
  @@map("telegram_messages")
}

enum WebhookStatus {
  pending
  success
  failed
  dead
}

model Webhook {
  id        String   @id @default(uuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name      String
  url       String
  secret    String
  active    Boolean  @default(true)
  events    String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  instances  WebhookInstance[]
  deliveries WebhookDelivery[]

  @@index([ownerId])
  @@map("webhooks")
}

model WebhookInstance {
  webhookId  String
  webhook    Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  instanceId String
  instance   Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([webhookId, instanceId])
  @@index([instanceId])
  @@map("webhook_instances")
}

model WebhookDelivery {
  id            String        @id @default(uuid())
  webhookId     String
  webhook       Webhook       @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  instanceId    String?
  event         String
  status        WebhookStatus @default(pending)
  attempts      Int           @default(0)
  statusCode    Int?
  lastError     String?
  payload       Json
  nextAttemptAt DateTime      @default(now())
  createdAt     DateTime      @default(now())
  deliveredAt   DateTime?

  @@index([status, nextAttemptAt])
  @@index([webhookId, createdAt])
  @@map("webhook_deliveries")
}
