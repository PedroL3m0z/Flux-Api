# App
NODE_ENV=development
PORT=3000

# CORS (comma-separated origins, or * for all)
CORS_ORIGIN=*

# Postgres
DATABASE_URL=postgresql://flux:flux@localhost:5432/flux?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=3600s

# Static API key (header: x-api-key)
API_KEY=change-me-api-key

# Rate limiting (per ttl window)
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
