# ── Flux API ─────────────────────────────────────────────────────────
# Tudo aqui é OPCIONAL. Sem nenhuma variável definida, a app sobe usando o
# Postgres/Redis do docker-compose, gera segredos fortes automaticamente
# (salvos em ./data/secrets.json) e exibe a API key gerada no log UMA vez.
# Copie para `.env` apenas se quiser sobrescrever algo.

# ── Essencial em produção ────────────────────────────────────────────
# Defina sua própria API key (header x-api-key). Se vazio, é autogerada.
# API_KEY=
# Cria um admin no primeiro boot (os três juntos). Se vazios, crie o
# usuário depois via API/seed.
# SEED_EMAIL=
# SEED_USERNAME=
# SEED_PASSWORD=

# ── Banco & cache (defaults já apontam para o docker-compose) ────────
# Se DATABASE_URL ficar vazio, ele é derivado de POSTGRES_* / defaults.
# DATABASE_URL=postgresql://flux:flux@localhost:5432/flux?schema=public
# POSTGRES_USER=flux
# POSTGRES_PASSWORD=flux
# POSTGRES_DB=flux
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Portas do host no docker-compose (evita conflito com outros stacks)
# POSTGRES_HOST_PORT=5432
# REDIS_HOST_PORT=6379

# ── Segredos (autogerados se vazios; defina para fixar manualmente) ──
# JWT_SECRET=
# JWT_EXPIRES_IN=3600s
# TELEGRAM_SESSION_SECRET=
# Onde os segredos autogerados são persistidos:
# DATA_DIR=./data

# ── Ajustes avançados (têm defaults sensatos) ───────────────────────
# NODE_ENV=development
# PORT=3000
# CORS_ORIGIN=*
# COOKIE_SECURE=false
# THROTTLE_TTL=60000
# THROTTLE_LIMIT=100

# ── Telegram (opcional; api_id/api_hash também podem ir por instância) ─
# Get them from https://my.telegram.org (API development tools).
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
