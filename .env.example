# App
NODE_ENV=development
PORT=3000

# CORS (comma-separated origins, or * for all)
CORS_ORIGIN=*

# Postgres credentials (used by docker-compose to provision the DB
# and to build the container DATABASE_URL)
POSTGRES_USER=flux
POSTGRES_PASSWORD=flux
POSTGRES_DB=flux

# Postgres URL for the app (local dev points at localhost; docker-compose
# overrides host to "postgres" and rebuilds the URL from the vars above)
DATABASE_URL=postgresql://flux:flux@localhost:5432/flux?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# docker-compose host port overrides (avoid clashing with other local stacks)
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379

# JWT auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=3600s
# Mark the auth cookie Secure (only when serving behind HTTPS)
COOKIE_SECURE=false

# Static API key (header: x-api-key)
API_KEY=change-me-api-key

# Optional: seed an initial user on first boot (all three required)
SEED_EMAIL=
SEED_USERNAME=
SEED_PASSWORD=

# Rate limiting (per ttl window)
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Telegram (GramJS). api_id/api_hash are entered per instance in the dashboard;
# these are an optional global fallback when an instance omits them.
# Get them from https://my.telegram.org (API development tools).
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# 32+ char secret to encrypt persisted sessions at rest (recommended in prod):
#   openssl rand -hex 32
TELEGRAM_SESSION_SECRET=
